---
interface Props {
  videoId: string;
}

const { videoId } = Astro.props;
---

<div class="vimeo-embed">
  <iframe 
    src={`https://player.vimeo.com/video/${videoId}?h=0&title=0&byline=0&portrait=0`}
    title="Vimeo video player"
    frameborder="0"
    allow="autoplay; fullscreen; picture-in-picture"
    allowfullscreen
  ></iframe>
</div>

<style>
  .vimeo-embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #000;
  }
  
  iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
</style>
