---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';

// Get the first project's cover image for preloading (LCP optimization)
const firstProject = projects[0];
const firstImageBase = firstProject.coverImage.replace(/\.(jpg|jpeg|png)$/i, '');
const preloadImage = `${firstImageBase}-400w.webp`;

// Number of above-the-fold images to eagerly load (3 on desktop, but we load 6 to cover tablet/mobile)
const PRIORITY_COUNT = 6;
---

<Layout 
  title="Alex Baro | Award-Winning Video Editor in London"
  description="Portfolio of Alex Baro-Cayetano, an award-winning British-Spanish video editor in London. Work includes projects for PlayStation, Adidas, BMW, Sony Music, Vice Media, and more."
  keywords="video editor portfolio, London video editor, commercial video editing, music video editor, brand content creator, Alex Baro work"
  preloadImage={preloadImage}
>
  <section class="work-page">
    <div class="project-grid">
      {projects.map((project, index) => (
        <ProjectCard
          slug={project.slug}
          title={project.title}
          year={project.year}
          coverImage={project.coverImage}
          priority={index < PRIORITY_COUNT}
        />
      ))}
    </div>
  </section>
</Layout>

<style>
  .work-page {
    padding: 40px;
    max-width: var(--max-width);
    margin: 0 auto;
  }
  
  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  
  @media (max-width: 1024px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 640px) {
    .work-page {
      padding: 20px;
    }
    
    .project-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>
