---
import Layout from '../../layouts/Layout.astro';
import VideoPlayer from '../../components/VideoPlayer.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';
import VimeoEmbed from '../../components/VimeoEmbed.astro';
import { projects, getProjectBySlug } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
  }));
}

const { slug } = Astro.params;
const project = getProjectBySlug(slug);

if (!project) {
  return Astro.redirect('/404');
}

// Check what content we have
const hasLocalVideos = project.videos.length > 0;
const hasYouTube = project.youtubeIds && project.youtubeIds.length > 0;
const hasVimeo = project.vimeoIds && project.vimeoIds.length > 0;
const hasContent = hasLocalVideos || hasYouTube || hasVimeo;

// Determine if videos are portrait (for grid layout)
const isPortrait = project.aspectRatio === 'portrait';

// Determine grid layout based on number of local videos
const videoCount = project.videos.length;
let gridClass = 'single';
if (videoCount === 2) gridClass = 'two-col';
else if (videoCount >= 3 && videoCount <= 4) gridClass = 'three-col';
else if (videoCount >= 5) gridClass = 'three-col';

// SEO - Generate dynamic description and keywords
const seoDescription = project.description 
  ? `${project.description} Video editing by Alex Baro-Cayetano.`
  : `${project.title} - Video editing project by Alex Baro-Cayetano, London-based video editor.`;

const seoKeywords = `${project.title}, video editing, Alex Baro, ${project.year}, commercial video, brand content`;
---

<Layout 
  title={`${project.title} | Alex Baro Video Editor`}
  description={seoDescription}
  keywords={seoKeywords}
  image={project.coverImage}
  type="article"
>
  <article class="project-page">
    <header class="project-header">
      <h1 class="project-title">{project.title}</h1>
      {project.description && (
        <p class="project-description">{project.description}</p>
      )}
    </header>
    
    {hasContent ? (
      <div class="project-content">
        {/* Local MP4 Videos */}
        {hasLocalVideos && (
          <div class:list={["video-grid", gridClass, { portrait: isPortrait }]}>
            {project.videos.map((videoId) => (
              <div class="video-item">
                <VideoPlayer videoId={videoId} portrait={isPortrait} />
              </div>
            ))}
          </div>
        )}
        
        {/* YouTube Embeds */}
        {hasYouTube && (
          <div class="embed-grid">
            {project.youtubeIds!.map((videoId) => (
              <div class="embed-item">
                <YouTubeEmbed videoId={videoId} />
              </div>
            ))}
          </div>
        )}
        
        {/* Vimeo Embeds */}
        {hasVimeo && (
          <div class="embed-grid">
            {project.vimeoIds!.map((videoId) => (
              <div class="embed-item">
                <VimeoEmbed videoId={videoId} />
              </div>
            ))}
          </div>
        )}
      </div>
    ) : (
      <div class="no-content">
        <p>Content coming soon.</p>
      </div>
    )}
    
    <nav class="project-nav">
      <a href="/" class="back-link">&larr; Back to Work</a>
    </nav>
  </article>
</Layout>

<style>
  .project-page {
    padding: 60px 40px;
    max-width: var(--max-width);
    margin: 0 auto;
  }
  
  .project-header {
    max-width: 800px;
    margin-bottom: 50px;
  }
  
  .project-title {
    font-size: 2rem;
    font-weight: 500;
    margin-bottom: 16px;
    line-height: 1.3;
  }
  
  .project-description {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }
  
  .project-content {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  
  /* Video grid layouts for local videos */
  .video-grid {
    display: grid;
    gap: 24px;
  }
  
  .video-grid.single {
    grid-template-columns: 1fr;
    max-width: 800px;
  }
  
  .video-grid.single.portrait {
    max-width: 400px;
  }
  
  .video-grid.two-col {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .video-grid.two-col.portrait {
    max-width: 700px;
  }
  
  .video-grid.three-col {
    grid-template-columns: repeat(3, 1fr);
  }
  
  .video-item {
    width: 100%;
  }
  
  /* Embed grid for YouTube/Vimeo */
  .embed-grid {
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr;
    max-width: 900px;
  }
  
  .embed-item {
    width: 100%;
  }
  
  .no-content {
    padding: 80px 40px;
    text-align: center;
    color: var(--color-text-secondary);
    background: #f9f9f9;
    border-radius: 8px;
  }
  
  .project-nav {
    margin-top: 60px;
    padding-top: 30px;
    border-top: 1px solid var(--color-border);
  }
  
  .back-link {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    transition: color 0.2s ease;
  }
  
  .back-link:hover {
    color: var(--color-text);
  }
  
  @media (max-width: 900px) {
    .video-grid.three-col {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 640px) {
    .project-page {
      padding: 40px 20px;
    }
    
    .project-title {
      font-size: 1.5rem;
    }
    
    .project-description {
      font-size: 1rem;
    }
    
    .video-grid.two-col,
    .video-grid.three-col {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    
    .video-grid.single.portrait {
      max-width: 280px;
      margin: 0 auto;
    }
  }
</style>
